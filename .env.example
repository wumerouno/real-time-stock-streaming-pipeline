# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRADE_TOPIC=stock-trades
KAFKA_DLQ_TOPIC=stock-trades-dlq
KAFKA_ANOMALY_TOPIC=stock-anomalies
KAFKA_AGGREGATE_TOPIC=stock-aggregates
KAFKA_CONSUMER_GROUP=stock-streaming-pipeline

# Streaming controls
EVENT_RATE_PER_SECOND=50
OUT_OF_ORDER_RATE=0.12
INVALID_EVENT_RATE=0.01
ANOMALY_RATE=0.015
WATERMARK_DELAY=2 minutes
MAX_OFFSETS_PER_TRIGGER=5000
TRIGGER_INTERVAL=10 seconds
CHECKPOINT_ROOT=data/checkpoints
DELTA_ROOT=data/delta
METRICS_ROOT=data/metrics

# Optional Snowflake integration
SNOWFLAKE_ENABLED=false
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=STREAMING_WH
SNOWFLAKE_DATABASE=STOCK_STREAMING
SNOWFLAKE_SCHEMA=MARKET
